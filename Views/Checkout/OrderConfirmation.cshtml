@model int
@{
    ViewData["Title"] = "Order Confirmed";
    Layout = "_ShopLayout";
}
<div class="text-center py-5">
    <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
    <h2 class="mt-4">Thank You for Your Order!</h2>
    <p class="text-muted">Your order #@Model has been placed successfully.</p>
    <p class="text-muted">You will receive an email confirmation shortly.</p>
    <a asp-controller="Shop" asp-action="Index" class="btn btn-artisan mt-3">Continue Shopping</a>
</div>

