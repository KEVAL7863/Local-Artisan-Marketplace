@{
    ViewData["Title"] = "Payment";
    Layout = "_ShopLayout";
    var cart = ViewBag.Cart as List<Local_Artisan_MarketPlace.Models.CartItem> ?? new List<Local_Artisan_MarketPlace.Models.CartItem>();
    var subtotal = (decimal)ViewBag.Subtotal;
    var shipping = (decimal)ViewBag.Shipping;
    var tax = (decimal)ViewBag.Tax;
    var total = (decimal)ViewBag.Total;
}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Cart</a></li>
        <li class="breadcrumb-item"><a asp-controller="Checkout" asp-action="Shipping">Shipping</a></li>
        <li class="breadcrumb-item active">Payment</li>
        <li class="breadcrumb-item">Review</li>
    </ol>
</nav>
<div class="row">
    <div class="col-lg-8">
        <h4 class="mb-4">Payment Method</h4>
        <form asp-action="PlaceOrder" method="post">
            @Html.AntiForgeryToken()
            <div class="form-check border rounded p-3 mb-2">
                <input type="radio" name="PaymentMethod" value="Card" class="form-check-input" id="card" checked />
                <label class="form-check-label w-100" for="card">
                    <strong>Credit/Debit Card</strong>
                    <div class="mt-2 small text-muted">Visa, Mastercard, RuPay</div>
                    <div class="mt-3">
                        <div class="mb-2">
                            <label class="form-label small">Card Number</label>
                            <input type="text" class="form-control" placeholder="0000 0000 0000 0000" maxlength="19" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small">Name on Card</label>
                            <input type="text" class="form-control" placeholder="Enter name on card" />
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <label class="form-label small">Expiry Date</label>
                                <input type="text" class="form-control" placeholder="MM/YY" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small">CVV</label>
                                <input type="password" class="form-control" placeholder="***" />
                            </div>
                        </div>
                    </div>
                </label>
            </div>
            <div class="form-check border rounded p-3 mb-2">
                <input type="radio" name="PaymentMethod" value="PayPal" class="form-check-input" id="paypal" />
                <label class="form-check-label" for="paypal"><strong>PayPal</strong></label>
            </div>
            <div class="form-check border rounded p-3 mb-3">
                <input type="radio" name="PaymentMethod" value="UPI" class="form-check-input" id="upi" />
                <label class="form-check-label" for="upi"><strong>UPI</strong></label>
            </div>
            <div class="form-check mb-3">
                <input type="checkbox" class="form-check-input" id="sameAddr" checked />
                <label class="form-check-label" for="sameAddr">Billing address same as shipping</label>
            </div>
            <a asp-controller="Checkout" asp-action="Shipping" class="btn btn-link p-0"><i class="fas fa-arrow-left me-1"></i>RETURN TO SHIPPING</a>
            <button type="submit" class="btn btn-artisan ms-3">PLACE ORDER</button>
        </form>
    </div>
    <div class="col-lg-4">
        <div class="order-summary-box">
            <h5 class="mb-3">Order Summary</h5>
            @foreach (var item in cart)
            {
                <div class="d-flex align-items-center mb-3">
                    <img src="@(item.ProductImageUrl ?? "/images/placeholder.png")" class="cart-item-img me-2" alt="" />
                    <div class="flex-grow-1">
                        <div class="small text-muted">@(item.CategoryName ?? "")</div>
                        <strong>@item.ProductName</strong>
                    </div>
                    <span>₹@item.TotalPrice.ToString("N2")</span>
                </div>
            }
            <hr />
            <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><span>₹@subtotal.ToString("N2")</span></div>
            <div class="d-flex justify-content-between mb-2"><span>Estimated Shipping</span><span>@(shipping == 0 ? "FREE" : "₹" + shipping.ToString("N2"))</span></div>
            <div class="d-flex justify-content-between mb-2"><span>Estimated Taxes</span><span>₹@tax.ToString("N2")</span></div>
            <hr />
            <div class="d-flex justify-content-between mb-3"><strong>Total</strong><strong class="h5">₹@total.ToString("N2")</strong></div>
            <div class="small">
                <p class="mb-1"><i class="fas fa-lock me-2"></i><strong>SECURE CHECKOUT</strong></p>
                <p class="text-muted small">Your personal information is encrypted and processed securely.</p>
                <p class="mb-1"><i class="fas fa-heart me-2"></i><strong>SUPPORT LOCAL</strong></p>
                <p class="text-muted small">Your purchase directly supports independent artisans and creators.</p>
            </div>
        </div>
    </div>
</div>

