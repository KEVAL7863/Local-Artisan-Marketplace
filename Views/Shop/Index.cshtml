@model List<Local_Artisan_MarketPlace.Models.Product>
@{
    ViewData["Title"] = "Shop";
    Layout = "_ShopLayout";
}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item active">Shop</li>
    </ol>
</nav>
<h2 class="mb-4">Shop</h2>
@if (ViewBag.Categories is List<Local_Artisan_MarketPlace.Models.Category> categories)
{
    <div class="mb-4">
        <a class="btn btn-outline-secondary me-2" asp-action="Index">All</a>
        @foreach (var cat in categories)
        {
            <a class="btn btn-outline-secondary me-2" asp-action="Index" asp-route-categoryId="@cat.Id">@cat.Name</a>
        }
    </div>
}
<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-md-6 col-lg-3">
            <div class="card product-card h-100">
                <a asp-action="Product" asp-route-id="@product.Id">
                    <img src="@(product.ImageUrl ?? "/images/placeholder.png")" class="card-img-top" alt="@product.Name" />
                </a>
                <div class="card-body">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="price">₹@product.Price.ToString("N2")</p>
                    <form asp-action="AddToCart" method="post" class="d-inline">
                        <input type="hidden" name="productId" value="@product.Id" />
                        <input type="hidden" name="quantity" value="1" />
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-artisan btn-sm">Add to Cart</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
@if (!Model.Any())
{
    <p class="text-muted">No products found.</p>
}

