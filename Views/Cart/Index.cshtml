@model List<Local_Artisan_MarketPlace.Models.CartItem>
@{
    ViewData["Title"] = "Your Cart";
    Layout = "_ShopLayout";
    var subtotal = (decimal)ViewBag.Subtotal;
    var shipping = (decimal)ViewBag.Shipping;
    var tax = (decimal)ViewBag.Tax;
    var total = (decimal)ViewBag.Total;
    var related = ViewBag.RelatedProducts as List<Local_Artisan_MarketPlace.Models.Product> ?? new List<Local_Artisan_MarketPlace.Models.Product>();
}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item active">Shopping Cart</li>
    </ol>
</nav>
<h2 class="mb-2">Your Cart</h2>
<p class="text-muted mb-4">@Model.Sum(c => c.Quantity) ITEMS SELECTED</p>
<div class="row">
    <div class="col-lg-8">
        @foreach (var item in Model)
        {
            <div class="card mb-3 p-3">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <img src="@(item.ProductImageUrl ?? "/images/placeholder.png")" class="cart-item-img" alt="@item.ProductName" />
                    </div>
                    <div class="col">
                        <h6 class="mb-1">@item.ProductName</h6>
                        <p class="small text-muted mb-2">@item.ShortDescription</p>
                        <p class="mb-0 fw-bold">₹@item.Price.ToString("N2")</p>
                    </div>
                    <div class="col-auto">
                        <form asp-action="UpdateQuantity" method="post" class="d-inline">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <div class="d-flex align-items-center">
                                <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="qty-btn">−</button>
                                <span class="mx-2">@item.Quantity</span>
                                <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="qty-btn">+</button>
                            </div>
                            @Html.AntiForgeryToken()
                        </form>
                    </div>
                    <div class="col-auto">
                        <form asp-action="Remove" method="post" class="d-inline">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-link text-danger p-0 small">REMOVE</button>
                        </form>
                    </div>
                </div>
            </div>
        }
        <a asp-controller="Shop" asp-action="Index" class="btn btn-link p-0"><i class="fas fa-arrow-left me-1"></i>CONTINUE SHOPPING</a>
    </div>
    <div class="col-lg-4">
        <div class="order-summary-box">
            <h5 class="mb-3">Order Summary</h5>
            <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><span>₹@subtotal.ToString("N2")</span></div>
            <div class="d-flex justify-content-between mb-2"><span>Estimated Shipping</span><span class="text-success">@(shipping == 0 ? "FREE" : "₹" + shipping.ToString("N2"))</span></div>
            <div class="d-flex justify-content-between mb-2"><span>Tax Included</span><span>₹@tax.ToString("N2")</span></div>
            <hr />
            <div class="d-flex justify-content-between mb-3"><strong>Total</strong><strong>₹@total.ToString("N2")</strong></div>
            <a asp-controller="Checkout" asp-action="Shipping" class="btn btn-artisan w-100">PROCEED TO CHECKOUT →</a>
            <div class="mt-3 small">
                <p class="mb-1"><i class="fas fa-shield-alt me-2"></i><strong>SECURE CHECKOUT</strong></p>
                <p class="text-muted small">Your personal information is encrypted and processed securely.</p>
                <p class="mb-1"><i class="fas fa-heart me-2"></i><strong>SUPPORT LOCAL</strong></p>
                <p class="text-muted small">Your purchase directly supports independent artisans and creators.</p>
            </div>
        </div>
    </div>
</div>
@if (related.Any())
{
    <hr class="my-5" />
    <h4>You might also like</h4>
    <div class="row g-4">
        @foreach (var p in related)
        {
            <div class="col-6 col-md-3">
                <a asp-controller="Shop" asp-action="Product" asp-route-id="@p.Id" class="text-decoration-none text-dark">
                    <div class="card product-card h-100">
                        <img src="@(p.ImageUrl ?? "/images/placeholder.png")" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@p.Name" />
                        <div class="card-body">
                            <h6 class="card-title">@p.Name</h6>
                            <p class="price mb-0">₹@p.Price.ToString("N2")</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

