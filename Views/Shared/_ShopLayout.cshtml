@inject Local_Artisan_MarketPlace.Services.CartService CartService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Artisan Market</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header class="shop-header">
        <nav class="navbar navbar-expand-lg container">
            <a class="navbar-brand" asp-controller="Shop" asp-action="Index">
                <i class="fas fa-store me-2"></i>Artisan Market
            </a>
            <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarShop">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarShop">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Shop" asp-action="Index">SHOP</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                </ul>
                <form class="d-flex me-3" asp-controller="Shop" asp-action="Index" method="get">
                    <input class="form-control" name="search" type="search" placeholder="Search unique crafts..." style="max-width: 250px;" />
                    <button class="btn btn-outline-light ms-2" type="submit"><i class="fas fa-search"></i></button>
                </form>
                <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                    <i class="fas fa-shopping-bag fa-lg"></i>
                    <span class="cart-badge position-absolute top-0 start-100 translate-middle">@CartService.GetCartCount()</span>
                </a>
                <span class="nav-link">@User.Identity?.Name</span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-link nav-link p-0 ms-2">Logout</button>
                </form>
            </div>
        </nav>
    </header>
    <main class="container py-4">
        @RenderBody()
    </main>
    <footer class="shop-footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-store me-2"></i>Artisan Market</h5>
                    <p class="small opacity-75">Connecting local makers with craft lovers worldwide. We believe in quality, sustainability, and the beauty of the handmade.</p>
                    <div class="mt-3">
                        <a href="#" class="me-3"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="#"><i class="fab fa-pinterest fa-lg"></i></a>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <div class="footer-title">QUICK LINKS</div>
                    <a href="#" class="d-block small mb-1">Track Order</a>
                    <a href="#" class="d-block small mb-1">Shipping Policy</a>
                    <a href="#" class="d-block small mb-1">Returns & Exchanges</a>
                    <a href="#" class="d-block small mb-1">Gift Cards</a>
                </div>
                <div class="col-md-2 mb-4">
                    <div class="footer-title">ABOUT US</div>
                    <a href="#" class="d-block small mb-1">Our Story</a>
                    <a href="#" class="d-block small mb-1">The Artisans</a>
                    <a href="#" class="d-block small mb-1">Sustainability</a>
                    <a href="#" class="d-block small mb-1">FAQs</a>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="footer-title">JOIN OUR NEWSLETTER</div>
                    <p class="small opacity-75">Get early access to new collections and artisan stories.</p>
                    <div class="input-group">
                        <input type="email" class="form-control" placeholder="Your email" />
                        <button class="btn btn-artisan" type="button">JOIN</button>
                    </div>
                </div>
            </div>
            <hr class="border-secondary" />
            <div class="d-flex justify-content-between align-items-center small">
                <span>© @DateTime.Now.Year ARTISAN MARKET. ALL RIGHTS RESERVED.</span>
                <span>
                    <a href="#" class="me-3">Privacy Policy</a>
                    <a href="#" class="me-3">Terms of Service</a>
                    <a href="#">Accessibility</a>
                </span>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

