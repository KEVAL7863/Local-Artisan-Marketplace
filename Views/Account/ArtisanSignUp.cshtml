@model Local_Artisan_MarketPlace.Models.ArtisanSignUpViewModel
@{
    ViewData["Title"] = "Create Artisan Account";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ArtisanHub Marketplace</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <div class="auth-container">
        <!-- Left Section - Promotional -->
        <div class="auth-left">
            <div class="auth-left-content">
                <div class="badge">EST. 2024</div>
                <h2 class="promo-headline">Empower your craft.</h2>
                <p class="promo-description">Join a community of master artisans and connect with collectors who value unique, handcrafted precision.</p>
                <div class="community-info">
                    <div class="avatar-group">
                        <div class="avatar"></div>
                        <div class="avatar"></div>
                        <div class="avatar"></div>
                    </div>
                    <span>Joined by 10k+ creators</span>
                </div>
                <div class="copyright">ARTISANHUB MARKETPLACE © 2024</div>
            </div>
        </div>

        <!-- Right Section - Artisan Sign Up Form -->
        <div class="auth-right">
            <div class="auth-form-container">
                <div class="brand-icon">A</div>
                <h2 class="auth-title">Create your account</h2>
                <p class="auth-subtitle">Join our vibrant community of creators and shoppers today.</p>

                <form asp-action="ArtisanSignUp" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Account Type Selection (Artisan selected) -->
                    <div class="account-type-selection">
                        <label class="account-type-card">
                            <i class="fas fa-shopping-bag account-type-icon"></i>
                            <div class="account-type-label">Shopper</div>
                            <div class="account-type-desc">I want to buy</div>
                        </label>

                        <label class="account-type-card selected">
                            <i class="fas fa-pen account-type-icon"></i>
                            <div class="account-type-label">Artisan</div>
                            <div class="account-type-desc">I want to sell</div>
                        </label>
                    </div>

                    <div class="form-group">
                        <label asp-for="BusinessName" class="form-label">Business Name</label>
                        <div class="input-wrapper">
                            <i class="fas fa-building input-icon"></i>
                            <input asp-for="BusinessName" class="form-control" placeholder="Enter your business name" />
                        </div>
                        <span asp-validation-for="BusinessName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ArtisanType" class="form-label">Artisan Type</label>
                        <div class="input-wrapper">
                            <i class="fas fa-tools input-icon"></i>
                            <select asp-for="ArtisanType" class="form-control">
                                <option value="">Select specialty</option>
                                <option value="Pottery">Pottery</option>
                                <option value="Woodworking">Woodworking</option>
                                <option value="Textiles">Textiles</option>
                                <option value="Jewelry">Jewelry</option>
                                <option value="Metalwork">Metalwork</option>
                                <option value="Glasswork">Glasswork</option>
                                <option value="Leatherwork">Leatherwork</option>
                                <option value="Other">Other</option>
                            </select>
                            <i class="fas fa-chevron-down select-arrow"></i>
                        </div>
                        <span asp-validation-for="ArtisanType" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <div class="input-wrapper">
                            <i class="fas fa-at input-icon"></i>
                            <input asp-for="Email" class="form-control" placeholder="Enter your email address" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <div class="input-wrapper">
                            <i class="fas fa-lock input-icon"></i>
                            <input asp-for="Password" class="form-control" type="password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm</label>
                        <div class="input-wrapper">
                            <i class="fas fa-check input-icon"></i>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="AgreeToTerms" class="form-check-input" type="checkbox" required />
                            <label asp-for="AgreeToTerms" class="form-check-label">
                                I agree to the <a href="#" class="terms-link">Terms of Service</a> and <a href="#" class="terms-link">Privacy Policy</a>.
                            </label>
                        </div>
                        <span asp-validation-for="AgreeToTerms" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-auth-primary">Create Artisan Account →</button>
                </form>

                <div class="auth-footer">
                    <p>Already have an account? <a asp-action="Login" class="auth-link">Sign in here</a></p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

